# ==========================================================================
#  EnergieFlow – Beispiel-Umgebungsvariablen
#  Diese Datei nach  server/.env  kopieren und ausfüllen:
#     cp .env.example server/.env
# ==========================================================================

# --- Server -----------------------------------------------------------------
PORT=4000
# Geheimer Schlüssel zum Signieren der Login-Token (beliebige lange Zufallszeichenkette)
JWT_SECRET=bitte-hier-einen-langen-zufaelligen-string-eintragen

# Adresse des Frontends (für CORS und die OAuth-Weiterleitung)
CLIENT_URL=http://localhost:5173

# --- Google Login (OAuth 2.0) ----------------------------------------------
# Anlegen unter:  https://console.cloud.google.com/apis/credentials
#   1. OAuth-Zustimmungsbildschirm konfigurieren
#   2. "OAuth-Client-ID" -> Webanwendung
#   3. Autorisierte Weiterleitungs-URI:  http://localhost:4000/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/auth/google/callback

# --- Entwicklung ------------------------------------------------------------
# Wenn true, ist ein einfacher Test-Login ohne Google möglich (NUR lokal nutzen!).
# So lässt sich die Anwendung sofort ausprobieren, auch ohne Google-Zugangsdaten.
ALLOW_DEV_LOGIN=true

# ==========================================================================
#  EnergieFlow – Beispiel-Umgebungsvariablen
#  Kopieren nach  .env   (im Projektwurzelverzeichnis):
#     cp .env.example .env
#
#  Hinweis: Es gibt KEINE Geheimnisse mehr (kein JWT_SECRET, kein OAuth).
#  Die Anmeldung läuft ausschließlich über Benutzername + Passwort.
# ==========================================================================

# Port, über den die GESAMTE Anwendung läuft (Frontend + API + WebSocket).
PORT=3000

# Kostenfaktor für die bcrypt-Passwort-Hashes (höher = sicherer, aber langsamer).
BCRYPT_ROUNDS=10
